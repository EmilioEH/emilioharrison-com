---
import RecipeLayout from '../layouts/RecipeLayout.astro'
import RecipeManagerClient from '../components/recipe-manager/RecipeManager'
import { getEmailList } from '../lib/env'

// This page used to `await db.getDocument('users', userId)` here — a blocking Firestore round
// trip (plus, on a cold Worker isolate, the JWT-sign + OAuth-exchange dance to authenticate that
// call) before the HTML shell could be sent at all, even though `RecipeManagerClient` below is
// `client:only="react"` and renders nothing server-side anyway. See PERFORMANCE-PLAN.md P6+P7:
// the shell now renders immediately with cheap/default values, and the client's `useBootstrap()`
// hook (in RecipeManager.tsx) resolves the real `displayName`/`isAdmin` from
// `GET /api/bootstrap` right after mount, updating RecipeManager's state once it arrives.
// Identity comes from the middleware-verified session (Astro.locals.session), never raw
// cookies — see lib/session.ts. `displayName` stays at the uid default until bootstrap
// resolves the Firestore-verified value client-side.
const session = Astro.locals.session
const userId = session?.uid
const displayName = userId
let isAdmin = false

const isTestMode = import.meta.env.PUBLIC_TEST_MODE === 'true'
const isTestUser = userId === 'TestUser' || userId === 'test_user'

if (isTestMode && isTestUser) {
  // BYPASS: In Test Mode, trust the TestUser completely to avoid "Split Brain" issues
  // between Client Mocks (MSW) and Server Real DB (Firestore)
  isAdmin = true
} else if (session?.email) {
  // Cheap, synchronous admin check against the session's verified email — same pattern
  // used server-side for admin gating without a Firestore round trip (see the PATCH/DELETE
  // handlers in api/families/current.ts).
  const adminEmails = getEmailList(Astro, 'ADMIN_EMAILS')
  isAdmin = adminEmails.includes(session.email.toLowerCase())
}
---

<RecipeLayout title="My Recipes" isAdmin={isAdmin}>
  <RecipeManagerClient client:only="react" user={displayName} isAdmin={isAdmin} />
</RecipeLayout>
